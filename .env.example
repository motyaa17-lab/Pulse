# Copy to apps/server/.env and apps/web/.env.local as needed

# Database
DATABASE_URL=postgresql://pulse:pulse_dev@localhost:5432/pulse?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate strong secrets in production)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# S3-compatible (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pulseminio
S3_SECRET_KEY=pulseminio_dev
S3_BUCKET=pulse-media
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/pulse-media

# Web (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
