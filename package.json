{
  "name": "pulse-messenger",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w @pulse/server\" \"npm run dev -w @pulse/web\"",
    "build": "turbo run build",
    "lint": "npm run lint -w @pulse/server && npm run lint -w @pulse/web",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "prepare": "husky || true",
    "db:generate": "npm run prisma:generate -w @pulse/server",
    "db:migrate": "npm run prisma:migrate -w @pulse/server",
    "db:seed": "npm run prisma:seed -w @pulse/server",
    "test": "npm run test -w @pulse/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "effect": "^3.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "turbo": "^2.5.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "validator": "13.12.0",
    "libphonenumber-js": "1.11.1"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001787",
    "libphonenumber-js": "1.11.1",
    "object-hash": "^3.0.0",
    "tailwind-merge": "^3.0.2",
    "validator": "13.12.0"
  }
}
